// Référence du modèle — runtime : client Supabase (`SUPABASE_SERVICE_ROLE_KEY`).
// Migrations SQL : ./migrations/ (appliquer via SQL Editor Supabase si besoin).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CLIENT
  ARTISAN
  ADMIN
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  REJECTED
}

/// Fourchette de prix ressentie par le client
enum PriceBracket {
  UNDER_EXPECTED
  AS_EXPECTED
  ABOVE_EXPECTED
  MUCH_ABOVE
}

enum DeadlinesKept {
  YES
  PARTIAL
  NO
}

enum AvailabilityRating {
  EASY
  OK
  DIFFICULT
}

enum PaymentType {
  BANK_TRANSFER
  CHECK
  CASH
  CARD
  INSTALLMENTS
  OTHER
}

/// Cohérence montant payé vs devis initial
enum QuoteAccuracy {
  MATCHED
  SLIGHTLY_OVER
  MUCH_OVER
  UNDER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(CLIENT)
  /// Hash bcrypt (connexion email / mot de passe) — null si compte sans mot de passe (futur SSO).
  passwordHash   String?
  /// Validation email : renseignée à l’inscription pour l’instant ; envoi de lien à brancher plus tard.
  emailVerified  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artisanProfile ArtisanProfile?
  reviews        Review[]
  /// Demandes de devis passées en étant connecté (ProLead).
  buyerLeads     ProLead[] @relation("BuyerProLeads")
  chatbotLogs    ChatbotLog[]
  /// Dépôts Kbis soumis avant association SIREN (statut APPROVED / REJECTED).
  proKbisVerifications ProKbisVerification[]
}

/// Inscription en attente : mot de passe déjà hashé, code OTP envoyé par e-mail (une ligne par e-mail).
model SignupOtp {
  id           String   @id @default(cuid())
  email        String   @unique
  codeHash     String
  expiresAt    DateTime
  attempts     Int      @default(0)
  name         String?
  passwordHash String
  role         UserRole
  lastSentAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([expiresAt])
}

/// Échanges enregistrés depuis le widget « Bot de ton pote » (pas de fichier image en base).
model ChatbotLog {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  /// Identifiant de session côté navigateur pour regrouper les messages d’une même conversation.
  clientSessionId String?
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  choiceId        String
  step            String
  userText        String?  @db.Text
  assistantText   String   @db.Text
  usedVision      Boolean  @default(false)

  @@index([createdAt])
  @@index([userId])
  @@index([clientSessionId])
}

/// Référentiel « type d’artisan » (table `BtpMetier` Supabase).
model BtpMetier {
  id        String          @id
  label     String
  codeNaf   String
  sortOrder Int             @default(0)
  prestations BtpPrestation[]
}

/// Prestations précises par métier (`BtpPrestation` Supabase).
model BtpPrestation {
  id              String    @id
  metierId        String
  metier          BtpMetier @relation(fields: [metierId], references: [id], onDelete: Cascade)
  label           String
  pricedBySurface Boolean   @default(false)
  /// M2 | ML | M3 | UNIT | FORFAIT — unité du prix pour comparer les avis.
  priceUnit       String    @default("FORFAIT")
  sortOrder       Int       @default(0)

  @@index([metierId])
}

/// Guide bricolage DIY (URL /conseils/[slug], alimenté par le chatbot ou seed).
model DiyKnowledgeArticle {
  id             String   @id
  slug           String   @unique
  metierId       String
  prestationId   String
  title          String
  excerpt        String?
  bodyMarkdown   String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([metierId, prestationId])
  @@index([metierId])
  @@index([createdAt])
}

/// Dépôt Kbis + résultat de la vérification IA (SIREN document vs déclaré).
model ProKbisVerification {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  declaredSiren    String
  storagePath      String
  /// APPROVED | REJECTED
  status           String
  aiExtractedSiren String?
  aiConfidence     String?
  aiNotes          String?  @db.Text
  /// Date « À jour au … » lue sur le document (YYYY-MM-DD).
  kbisExtractDate  String?
  rejectionReason  String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

/// Compte revendiqué par un artisan (lié au SIREN) — options premium Stripe plus tard
model ArtisanProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  siren        String    @unique
  verifiedAt   DateTime?
  /// Affiché uniquement si abonnement premium actif
  phonePublic  String?
  /// Optionnel : site, réseaux — { "website"?, "instagram"?, "facebook"?, "linkedin"? }
  contactLinks Json?
  stripeSubId  String?
  premiumUntil DateTime?
  /// Clientèle : particuliers
  servesParticuliers Boolean @default(true)
  /// Clientèle : professionnels / entreprises
  servesProfessionnels Boolean @default(false)
  /// Sous-activités cochées par famille métier : { "plomberie": ["robinetterie", ...], ... } (ids stables, voir `BtpPrestation` / seed)
  sousActivitesSelection Json?
  /// Vitrine web (Pro Vitrine+) : accroche courte.
  vitrineHeadline String?
  /// Vitrine web (Pro Vitrine+) : texte de présentation.
  vitrineBio      String? @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projectPhotos ProjectPhoto[]
  leads         ProLead[]
  projects      ProProject[]
  catalogItems  ProCatalogItem[]
}

/// Demandes entrantes (Pro Relation+)
model ProLead {
  id        String   @id @default(cuid())
  siren     String
  artisan   ArtisanProfile @relation(fields: [siren], references: [siren], onDelete: Cascade)
  /// Compte acheteur (si demande passée connecté) — liste côté /compte/demandes
  requesterUserId String?
  requesterUser   User?   @relation("BuyerProLeads", fields: [requesterUserId], references: [id], onDelete: SetNull)
  status    String   @default("NEW")
  fullName  String?
  email     String?
  phone     String?
  message   String?  @db.Text
  source    String   @default("entreprise")
  /// Référentiel BTP : métier choisi par le demandeur (optionnel).
  metierId  String?
  /// Référentiel BTP : prestation choisie (optionnel).
  prestationId String?
  /// Dossier « pour devis » : surfaces, photos (liens), urgence, etc. (JSON versionné).
  requestPayload Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments ProLeadAttachment[]
  aiDraft     ProLeadAiDraft?

  @@index([siren])
  @@index([requesterUserId])
  @@index([status])
  @@index([createdAt])
  @@index([prestationId])
}

model ProLeadAttachment {
  id           String   @id @default(cuid())
  leadId       String
  lead         ProLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  storagePath  String
  mimeType     String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([leadId])
}

/// Brouillon généré (IA ou heuristique) pour aider le pro à chiffrer.
model ProLeadAiDraft {
  id             String   @id @default(cuid())
  leadId         String   @unique
  lead           ProLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  /// PENDING | OK | ERROR | STUB
  status         String   @default("PENDING")
  model          String?
  summary        String?  @db.Text
  missingFields  Json?
  suggestedLines Json?
  assumptions    Json?
  /// Analyse contextualisée : thème, observation (photo ou texte), vigilance, niveau.
  vigilancePoints Json?
  confidence     Int?
  rawResponse    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([leadId])
}

/// Pilotage (Pro Pilotage) : chantier / projet interne
model ProProject {
  id        String   @id @default(cuid())
  siren     String
  artisan   ArtisanProfile @relation(fields: [siren], references: [siren], onDelete: Cascade)
  title     String
  clientName String?
  status    String   @default("OPEN")
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes    ProQuote[]
  invoices  ProInvoice[]
  timeEntries ProTimeEntry[]
  expenses  ProExpense[]

  @@index([siren])
  @@index([status])
}

model ProQuote {
  id        String   @id @default(cuid())
  projectId String
  project   ProProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number    String
  status    String   @default("DRAFT")
  currency  String   @default("EUR")
  totalCents Int     @default(0)
  linesJson Json?
  issuedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model ProInvoice {
  id        String   @id @default(cuid())
  projectId String
  project   ProProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number    String
  status    String   @default("DRAFT")
  currency  String   @default("EUR")
  totalCents Int     @default(0)
  linesJson Json?
  issuedAt  DateTime?
  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model ProTimeEntry {
  id        String   @id @default(cuid())
  projectId String
  project   ProProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  minutes   Int
  workDate  DateTime @db.Date
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([workDate])
}

model ProExpense {
  id        String   @id @default(cuid())
  projectId String
  project   ProProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  amountCents Int
  expenseDate DateTime @db.Date
  category  String   @default("OTHER")
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([expenseDate])
}

/// Catalogue devis / factures (Pilotage) : produit, main d'œuvre (ex. TJM si unité « jour »), sous-traitance.
model ProCatalogItem {
  id                     String   @id @default(cuid())
  siren                  String
  artisan                ArtisanProfile @relation(fields: [siren], references: [siren], onDelete: Cascade)
  /// PRODUCT | LABOR | SUBCONTRACT
  kind                   String
  label                  String
  description            String?  @db.Text
  unit                   String   @default("forfait")
  purchaseUnitPriceCents Int?
  saleUnitPriceCents     Int?
  sortOrder              Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([siren])
  @@index([siren, kind])
}

model Review {
  id            String               @id @default(cuid())
  siren         String
  authorId      String
  author        User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  /// Pseudo affiché sur l’avis (saisi au dépôt).
  authorPseudo  String?
  /// Clé Storage (bucket public) — image « avant travaux ».
  photoBeforeStorageKey String?
  /// Clé Storage — image « après travaux ».
  photoAfterStorageKey  String?
  ratingOverall Int
  comment       String?
  priceBracket  PriceBracket?
  deadlinesKept DeadlinesKept?
  availability  AvailabilityRating?
  paymentType   PaymentType?
  quoteVsPaid   QuoteAccuracy?
  /// Famille métier de la prestation réalisée (id `BtpMetier`).
  prestationMetierId   String?
  /// Sous-activité réalisée (id stable `BtpPrestation`).
  prestationActiviteId String?
  /// Montant total payé TTC ou principal, en centimes d’euro (optionnel).
  amountPaidCents      Int?
  /// Surface de chantier en m² (prestations au m²) — optionnel.
  surfaceM2            Float?
  /// Même référentiel que `BtpPrestation.priceUnit` au moment du dépôt.
  priceUnit            String?
  linearMl             Float?
  volumeM3             Float?
  quantityUnits        Float?
  status        ReviewStatus         @default(PENDING)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  response ReviewResponse?

  @@unique([authorId, siren])
  @@index([siren])
  @@index([status])
}

/// Réponse artisan à un avis (disponibilité standard une fois compte vérifié)
model ReviewResponse {
  id        String   @id @default(cuid())
  reviewId  String   @unique
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}

model ProjectPhoto {
  id         String         @id @default(cuid())
  artisanId  String
  artisan    ArtisanProfile @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  storageKey String
  caption    String?
  createdAt  DateTime       @default(now())

  @@index([artisanId])
}
