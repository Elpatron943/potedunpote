# Copie ce fichier en .env et remplis les valeurs.
# https://supabase.com/dashboard → ton projet → Settings → Database

# --- Supabase (PostgreSQL) ---
# « Connection string » → onglet URI, mode « Transaction pooler » (port 6543) pour l’app.
# Ajoute souvent : ?pgbouncer=true  (Prisma + pooler)
# Exemple :
# DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Même base, connexion « directe » (port 5432) — obligatoire pour `prisma migrate dev` / `migrate deploy`.
# Dashboard → Connection string → « Direct connection » ou port 5432.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# En local sans Supabase (Postgres Docker, etc.) : tu peux mettre la MÊME URL pour les deux.
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lepotedunpote"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/lepotedunpote"

# --- App (déjà utilisés par le code) ---
AUTH_SECRET="min-32-caracteres-aleatoires-en-production"

# Optionnel : dépôt logo en prod
# LOGO_DEPOT_SECRET=""
