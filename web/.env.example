# Copie ce fichier en .env et remplis les valeurs.
#
# Guide : CONFIGURATION_ENV.md

# --- Supabase (API) — Project Settings → API ---
# URL du projet (https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=""
# Clé « anon » « public » (JWT)
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Clé « service_role » (secrète) — uniquement côté serveur / Netlify, jamais dans le navigateur.
# Remplace l’ancien accès Prisma / DATABASE_URL pour les requêtes base de données.
SUPABASE_SERVICE_ROLE_KEY=""

# --- App ---
AUTH_SECRET="min-32-caracteres-aleatoires-en-production"

# --- Assistant chat (OpenAI) ---
OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"

# --- Inscription (OTP e-mail, client & pro) ---
# En local sans clé : le code OTP est affiché dans le terminal du serveur (npm run dev).
# En production : compte https://resend.com — domaine d’expédition vérifié recommandé.
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="Inscription <onboarding@resend.dev>"

# Optionnel : dépôt logo en prod
# LOGO_DEPOT_SECRET=""
